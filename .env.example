# Email settings for SMTP (Optional - only required if you want to use the email feature)
EMAIL_USER=your_email@gmail.com
# For Gmail, you MUST use an App Password: https://support.google.com/accounts/answer/185833
EMAIL_PASS=your_app_password_here
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Local music directory (Optional - only required if you want to play local audio files)
# Provide the absolute path, e.g. C:\Users\anuj\Music
MUSIC_DIR=
